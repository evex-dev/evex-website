<div id="loader">
	<div class="data-stream" id="stream1"></div>
	<div class="data-stream" id="stream2"></div>
	<div class="data-stream" id="stream3"></div>
	<div class="data-stream" id="stream4"></div>
	<div class="error-overlay" id="errOverlay">CRITICAL FAILURE</div>
</div>

<style>
	#loader {
		position: fixed;
		inset: 0;
		background: #000;
		z-index: 10000;
		overflow: hidden;
		pointer-events: none;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20px;
		padding: 20px;
		font-family: var(--mono);
		font-size: 10px;
		color: #00ff00;
		transition: opacity 0.5s;
	}

	.data-stream {
		overflow: hidden;
		display: flex;
		flex-direction: column;
		gap: 2px;
		opacity: 0.6;
		height: 100%;
	}

	.data-stream:nth-child(even) {
		opacity: 0.3;
		font-size: 8px;
		margin-top: 50px;
	}

	:global(.log-line) {
		white-space: nowrap;
		line-height: 1;
	}

	#loader.glitch-active {
		animation: screen-shake 0.05s infinite alternate;
	}

	#loader.glitch-active :global(.log-line) {
		color: #ff3e3e;
		text-shadow: 2px 0 #00ffff, -2px 0 #ff00ff;
	}

	@keyframes screen-shake {
		0% { transform: translate(1px, 1px) rotate(0deg); }
		100% { transform: translate(-1px, -1px) rotate(0.1deg); }
	}

	.error-overlay {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		font-size: 6vw;
		font-weight: 700;
		color: white;
		background: #ff3e3e;
		padding: 10px 40px;
		text-transform: uppercase;
		z-index: 10001;
		display: none;
		mix-blend-mode: difference;
	}

	#loader.whiteout {
		background: #fff !important;
		transition: background 0.1s;
	}

	#loader.whiteout .data-stream,
	#loader.whiteout .error-overlay {
		display: none !important;
	}

	#loader.fade-out {
		opacity: 0;
		pointer-events: none;
	}
</style>

<script>
	const loader = document.getElementById('loader');
	const errOverlay = document.getElementById('errOverlay');
	const streams = [
		document.getElementById('stream1'),
		document.getElementById('stream2'),
		document.getElementById('stream3'),
		document.getElementById('stream4')
	];

	const charSet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789<>[]{}/\\|!@#$%^&*()_+=-";

	function generateRandomString(len: number) {
		let res = "";
		for (let i = 0; i < len; i++) {
			res += charSet[Math.floor(Math.random() * charSet.length)];
		}
		return res;
	}

	function addDataLine(stream: HTMLElement) {
		const line = document.createElement('div');
		line.className = 'log-line';

		const rand = Math.random();
		if (rand < 0.2) {
			line.textContent = `[ ${Math.random().toFixed(6)} ] ERROR_PANIC_0x${Math.floor(Math.random() * 100000).toString(16)}`;
		} else if (rand < 0.4) {
			line.textContent = generateRandomString(40);
		} else if (rand < 0.7) {
			line.textContent = `HEX ${Math.random().toString(16).slice(2, 20).toUpperCase()}`;
		} else {
			line.textContent = `MEMORY_DUMP: 0x${Math.floor(Math.random() * 1e9).toString(16)} >> COLLISION`;
		}

		stream.appendChild(line);
		if (stream.children.length > 50) stream.removeChild(stream.firstChild!);
	}

	let glitchPhase = 0;
	function runStreams() {
		if (!loader || !errOverlay) return;

		if (glitchPhase < 120) {
			streams.forEach(s => s && addDataLine(s));
			glitchPhase++;

			if (glitchPhase > 40) {
				loader.classList.add('glitch-active');
				if (Math.random() > 0.95) errOverlay.style.display = 'block';
				else errOverlay.style.display = 'none';
			}

			if (glitchPhase > 80) {
				loader.style.gridTemplateColumns = `repeat(${Math.floor(Math.random() * 6) + 2}, 1fr)`;
			}

			setTimeout(runStreams, Math.random() * 40 + 5);
		} else {
			errOverlay.textContent = "SYSTEM_COLLAPSE";
			errOverlay.style.display = 'block';
			errOverlay.style.background = '#000';
			errOverlay.style.color = '#fff';

			setTimeout(() => {
				loader.classList.add('whiteout');
				setTimeout(() => {
					loader.classList.add('fade-out');
				}, 200);
			}, 800);
		}
	}

	window.addEventListener('load', () => {
		setTimeout(runStreams, 200);
	});

	const urlGlitches = [
		"#ERROR_0xFB2", "#_GLITCH_", "#DECODING...", "#ACCESS_DENIED",
		"#SYSTEM_HALT", "#REBOOT_REQD", "#CRC_ERR", "#000000"
	];

	function triggerUrlGlitch() {
		const originalPath = window.location.pathname;
		const glitch = urlGlitches[Math.floor(Math.random() * urlGlitches.length)];
		window.history.replaceState(null, '', glitch);

		setTimeout(() => {
			window.history.replaceState(null, '', originalPath);
			setTimeout(triggerUrlGlitch, Math.random() * 25000 + 15000);
		}, Math.random() * 400 + 400);
	}

	setTimeout(triggerUrlGlitch, 6000);
</script>
