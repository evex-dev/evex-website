<div class="modal-overlay" id="ossModal">
	<div class="modal-content">
		<h2>OSS Projects</h2>
		<button class="modal-close" id="closeModal">Close</button>
		<div class="project-list">
			<a href="https://github.com/evex-dev/line.js" target="_blank" class="project-item">
				<div class="project-info">
					<h4>line.js</h4>
					<p>LINE Bot開発を加速させる TypeScriptライブラリ。</p>
				</div>
				<span class="project-tag">TypeScript</span>
			</a>
			<a href="https://github.com/evex-dev/hono.go" target="_blank" class="project-item">
				<div class="project-info">
					<h4>hono.go</h4>
					<p>Go言語で実装された、驚異的な速さを誇るAPIフレームワーク。</p>
				</div>
				<span class="project-tag">Go</span>
			</a>
			<a href="https://github.com/evex-dev" target="_blank" class="project-item">
				<div class="project-info">
					<h4>More on GitHub</h4>
					<p>その他のプロジェクトはGitHubをご確認ください。</p>
				</div>
				<span class="project-tag">OSS</span>
			</a>
		</div>
	</div>
</div>

<style>
	.modal-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.82);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		z-index: 1000;
		display: flex;
		justify-content: flex-end;
		padding: 40px;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
		visibility: hidden;
	}

	.modal-overlay[data-state="open"] {
		opacity: 1;
		pointer-events: auto;
		visibility: visible;
	}

	.modal-overlay[data-state="closing"] {
		opacity: 0;
		pointer-events: none;
		visibility: visible;
	}

	.modal-content {
		width: 100%;
		max-width: 600px;
		height: 100%;
		background: #080808;
		border: 1px solid rgba(255, 255, 255, 0.1);
		padding: 60px;
		position: relative;
		display: flex;
		flex-direction: column;
		overflow-y: auto;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
	}

	/* RGB Border Effect */
	.modal-content::before {
		content: '';
		position: absolute;
		inset: -2px;
		z-index: -1;
		background: conic-gradient(
			from 0deg,
			#ff0000,
			#ff8000,
			#ffff00,
			#00ff00,
			#00ffff,
			#0000ff,
			#8000ff,
			#ff00ff,
			#ff0000
		);
		animation: rotate-rgb 4s linear infinite;
		opacity: 0.5;
		filter: blur(5px);
	}

	@keyframes rotate-rgb {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.modal-content h2 {
		font-size: 60px;
		font-weight: 700;
		letter-spacing: -2px;
		margin-bottom: 60px;
		text-transform: uppercase;
		background: linear-gradient(to right, #fff, #888);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		text-shadow: 2px 0 #ff3e3e, -2px 0 #00ffff;
	}

	.modal-content[data-state="closing"] {
		animation: glitch-close 0.4s steps(2, end) forwards;
	}

	@keyframes glitch-close {
		0% { 
			transform: scale(1);
			opacity: 1;
			filter: none;
		}
		30% { 
			transform: scale(1.02) translateX(-10px);
			filter: hue-rotate(90deg) brightness(1.5);
		}
		60% { 
			transform: scale(0.98) translateX(10px);
			filter: hue-rotate(-90deg) contrast(150%);
		}
		100% { 
			transform: scale(0.9) translateX(50px);
			opacity: 0;
		}
	}

	.modal-close {
		position: absolute;
		top: 40px;
		right: 40px;
		font-family: var(--mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.6);
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		padding: 10px 20px;
		cursor: pointer;
		transition: all 0.3s ease;
		backdrop-filter: blur(4px);
	}

	.modal-close:hover {
		color: white;
		border-color: white;
		background: rgba(255, 255, 255, 0.15);
		box-shadow: 3px 0 #ff3e3e, -3px 0 #00ffff;
		animation: glitch-skew 0.2s infinite;
	}

	.project-item {
		border-bottom: 1px solid var(--border);
		padding: 40px 0;
		text-decoration: none;
		color: inherit;
		display: flex;
		justify-content: space-between;
		align-items: center;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		position: relative;
		overflow: hidden;
	}

	.project-item::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 1px;
		background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.5), transparent);
		transform: translateX(-100%);
		transition: transform 0.6s ease;
	}

	.project-item:hover {
		border-color: transparent;
		padding-left: 20px;
		background: rgba(255, 255, 255, 0.02);
	}

	.project-item:hover::after {
		transform: translateX(0);
	}

	.project-info h4 {
		font-size: 24px;
		font-weight: 500;
		margin-bottom: 10px;
		transition: color 0.3s ease;
	}

	.project-item:hover .project-info h4 {
		color: #00ffff;
		text-shadow: 2px 0 #ff3e3e, -2px 0 #00ffff;
		animation: glitch-skew 0.2s infinite;
	}

	.project-info p {
		color: var(--muted);
		font-size: 14px;
	}

	.project-tag {
		font-family: var(--mono);
		font-size: 10px;
		color: var(--muted);
		border: 1px solid var(--border);
		padding: 4px 10px;
		transition: all 0.3s ease;
	}

	.project-item:hover .project-tag {
		color: white;
		border-color: #ff00ff;
		box-shadow: 0 0 10px rgba(255, 0, 255, 0.3);
	}

	@media (max-width: 768px) {
		.modal-content { padding: 40px 30px; }
		.modal-content h2 { font-size: 40px; }
		.modal-close { top: 20px; right: 20px; }
	}
</style>

<script>
	const modal = document.getElementById('ossModal');
	const closeBtn = document.getElementById('closeModal');

	function openModal() {
		if (!modal) return;
		const content = modal.querySelector('.modal-content');
		if (content) content.removeAttribute('data-state');

		modal.setAttribute('data-state', 'open');
		document.body.style.overflow = 'hidden';
	}

	function closeModal() {
		if (!modal || modal.getAttribute('data-state') === 'closing') return;
		
		const content = modal.querySelector('.modal-content');
		if (!content) return;

		modal.setAttribute('data-state', 'closing');
		content.setAttribute('data-state', 'closing');

		const finalize = () => {
			modal.removeAttribute('data-state');
			content.removeAttribute('data-state');
			document.body.style.overflow = '';
			content.removeEventListener('animationend', finalize);
		};

		content.addEventListener('animationend', finalize);

		// Fallback
		setTimeout(finalize, 600);
	}

	closeBtn?.addEventListener('click', (e) => {
		e.stopPropagation();
		closeModal();
	});
	
	modal?.addEventListener('click', (e) => {
		if (e.target === modal) closeModal();
	});

	window.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && modal?.getAttribute('data-state') === 'open') {
			closeModal();
		}
	});

	window.addEventListener('open-modal', openModal);
</script>
